# Copy to .env and fill in. Do not commit .env (secrets).

# MongoDB Atlas: get URI from Atlas → Connect → Drivers → Node.js
# Format: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority
# - Use w=majority (not "majorityy" or other typos)
# - If password has special chars (@ # $ etc), encode them: https://www.urlencoder.org/
# - Atlas → Network Access: add your IP or 0.0.0.0/0 for development
MONGODB_URI=
MONGODB_DB_NAME=diet

# Optional: Gemini for AI diet generation and grocery list
# GEMINI_API_KEY=
# GEMINI_MODEL_NAME=gemini-1.5-flash
# DIET_MODE=gemini

# Server port (default 5000)
# PORT=5000

# Admin JWT (recommended in production)
# ADMIN_JWT_SECRET=your-secret-key
# JWT_SECRET=your-app-jwt-secret
